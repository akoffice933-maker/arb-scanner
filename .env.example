# === INFRASTRUCTURE ===
ENVIRONMENT=production

# Solana RPC (3 ноды для failover)
SOLANA_RPC_PRIMARY=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY
SOLANA_RPC_SECONDARY=https://solana-mainnet.g.alchemy.com/v2/YOUR_API_KEY
SOLANA_RPC_TERTIARY=https://mainnet.triton.one/rpc/YOUR_API_KEY

# Base RPC
BASE_RPC_PRIMARY=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY
BASE_RPC_SECONDARY=https://base-mainnet.quicknode.com/YOUR_API_KEY

# Jito
JITO_UUID=your-jito-uuid-here
JITO_AUTH_KEYPAIR=/app/keypairs/jito.json
SHREDSTREAM_ENDPOINT=mainnet.block-engine.jito.wtf

# === DATABASE ===
DATABASE_URL=postgresql://arb_user:arb_password@localhost:5432/arb_scanner
TIMESCALE_ENABLED=true

# === SCANNER SETTINGS ===
TARGET_NETWORKS=solana,base
MIN_LIQUIDITY_USD=50000
MIN_SPREAD_NET_PERCENT=0.15
MAX_SLIPPAGE_PERCENT=2.0
RPC_TIMEOUT_SECONDS=5.0
RPC_MAX_RETRIES=3

# === TIP SETTINGS ===
MAX_TIP_PERCENT_OF_PROFIT=30.0
TIP_FLOOR_SOL=0.001

# === ALERTS ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === METRICS ===
PROMETHEUS_PORT=9090

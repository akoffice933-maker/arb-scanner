# =============================================================================
# ARBITRAGE SCANNER v3.0 — ENVIRONMENT CONFIGURATION
# =============================================================================
# Скопируйте этот файл в .env и заполните значениями
# НИКОГДА не коммитьте .env файл в Git!
# =============================================================================

# -----------------------------------------------------------------------------
# INFRASTRUCTURE SETTINGS
# -----------------------------------------------------------------------------

# Окружение (production/development/testing)
ENVIRONMENT=production

# -----------------------------------------------------------------------------
# SOLANA RPC ENDPOINTS (Failover: Primary → Secondary → Tertiary)
# -----------------------------------------------------------------------------
# Получите бесплатные API ключи:
# - Helius: https://www.helius.dev/ (100 RPS бесплатно)
# - Alchemy: https://www.alchemy.com/ (300 RPS бесплатно)
# - Triton: https://triton.one/ (100 RPS бесплатно)
# - QuickNode: https://www.quicknode.com/ (платно, высокий лимит)

# Основной RPC (приоритет №1)
SOLANA_RPC_PRIMARY=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# Резервный RPC (приоритет №2, используется при сбое Primary)
SOLANA_RPC_SECONDARY=https://solana-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Третий RPC (приоритет №3, используется при сбое Secondary)
SOLANA_RPC_TERTIARY=https://mainnet.triton.one/rpc/YOUR_TRITON_API_KEY

# -----------------------------------------------------------------------------
# BASE RPC ENDPOINTS (Failover: Primary → Secondary)
# -----------------------------------------------------------------------------
# Получите бесплатные API ключи:
# - Alchemy Base: https://www.alchemy.com/ (300 RPS бесплатно)
# - QuickNode Base: https://www.quicknode.com/ (платно)

# Основной RPC для Base
BASE_RPC_PRIMARY=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_BASE_API_KEY

# Резервный RPC для Base
BASE_RPC_SECONDARY=https://base-mainnet.quicknode.com/YOUR_QUICKNODE_BASE_KEY

# -----------------------------------------------------------------------------
# JITO SHREDSTREAM SETTINGS (для Solana MEV защиты)
# -----------------------------------------------------------------------------
# Получите Jito UUID: https://jito.wtf/
# 1. Зарегистрируйтесь на Jito Network
# 2. Создайте bundle endpoint
# 3. Скопируйте UUID

# UUID вашего Jito bundle
JITO_UUID=your-jito-uuid-here

# Путь к файлу ключа авторизации (keypair в формате JSON)
# Сгенерируйте ключ: solana-keygen new -o jito-auth.json
JITO_AUTH_KEYPAIR=/app/keypairs/jito.json

# Endpoint Jito ShredStream (не менять)
SHREDSTREAM_ENDPOINT=mainnet.block-engine.jito.wtf

# -----------------------------------------------------------------------------
# DATABASE SETTINGS
# -----------------------------------------------------------------------------

# PostgreSQL подключение
# Формат: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Для Docker: postgresql://arb_user:arb_password@postgres:5432/arb_scanner
# Для локального: postgresql://arb_user:arb_password@localhost:5432/arb_scanner
DATABASE_URL=postgresql://arb_user:arb_password@localhost:5432/arb_scanner

# Включить TimescaleDB для временных рядов (true/false)
# TimescaleDB улучшает производительность запросов по времени
TIMESCALE_ENABLED=true

# -----------------------------------------------------------------------------
# SCANNER SETTINGS
# -----------------------------------------------------------------------------

# Сети для сканирования (через запятую)
# Варианты: solana, base
# Примеры:
#   TARGET_NETWORKS=solana         # Только Solana
#   TARGET_NETWORKS=base           # Только Base
#   TARGET_NETWORKS=solana,base    # Обе сети (рекомендуется)
TARGET_NETWORKS=solana,base

# Минимальная ликвидность пула в USD
# Пулы с ликвидностью ниже этого порога игнорируются
# Рекомендуемое значение: 50000 (для снижения риска проскальзывания)
MIN_LIQUIDITY_USD=50000

# Минимальный спред net для логирования (в процентах)
# Возможности со спредом ниже этого порога не логируются
# Рекомендуемое значение: 0.15 (0.15% после всех комиссий)
MIN_SPREAD_NET_PERCENT=0.15

# Максимальное проскальзывание (в процентах)
# Предупреждение, если проскальзывание превышает это значение
# Рекомендуемое значение: 2.0 (2%)
MAX_SLIPPAGE_PERCENT=2.0

# Таймаут RPC запроса (в секундах)
# При превышении запрос считается неудачным
# Рекомендуемое значение: 5.0 (5 секунд)
RPC_TIMEOUT_SECONDS=5.0

# Максимальное количество попыток RPC запроса
# При неудаче запрос повторяется это количество раз
# Рекомендуемое значение: 3
RPC_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# TIP SETTINGS (Jito Validator Tips)
# -----------------------------------------------------------------------------

# Максимальный процент от прибыли на тип валидатору
# Например, 30.0 означает не более 30% от прибыли
# Рекомендуемое значение: 30.0
MAX_TIP_PERCENT_OF_PROFIT=30.0

# Минимальный тип в SOL (floor)
# Даже если 30% от прибыли меньше, отправляется не меньше этого значения
# Рекомендуемое значение: 0.001 (0.001 SOL)
TIP_FLOOR_SOL=0.001

# -----------------------------------------------------------------------------
# TELEGRAM ALERTS SETTINGS
# -----------------------------------------------------------------------------
# Получите токен бота:
# 1. Откройте @BotFather в Telegram
# 2. Отправьте /newbot
# 3. Введите имя и username бота
# 4. Скопируйте полученный токен

# Токен Telegram бота (оставьте пустым для отключения алертов)
TELEGRAM_BOT_TOKEN=

# ID чата для уведомлений
# Как узнать:
# 1. Добавьте бота в чат/канал
# 2. Отправьте любое сообщение
# 3. Узнайте ID через @userinfobot
# 4. Для канала ID начинается с -100
TELEGRAM_CHAT_ID=

# Порог спреда для отправки алерта (в процентах)
# Алерты отправляются только при спреде выше этого значения
# Рекомендуемое значение: 1.0 (1%)
TELEGRAM_ALERT_THRESHOLD=1.0

# -----------------------------------------------------------------------------
# PROMETHEUS METRICS SETTINGS
# -----------------------------------------------------------------------------

# Порт для сервера метрик Prometheus
# Prometheus будет скрапить метрики по адресу http://localhost:9090
PROMETHEUS_PORT=9090

# Включить метрики (true/false)
METRICS_ENABLED=true

# -----------------------------------------------------------------------------
# LOGGING SETTINGS
# -----------------------------------------------------------------------------

# Уровень логирования
# Варианты: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Для продакшена: INFO или WARNING
# Для отладки: DEBUG
LOG_LEVEL=INFO

# Путь к файлу логов (оставьте пустым для вывода в консоль)
# LOG_FILE=/app/logs/scanner.log
LOG_FILE=

# -----------------------------------------------------------------------------
# ADVANCED SETTINGS (не менять без необходимости)
# -----------------------------------------------------------------------------

# Частота сканирования (в секундах)
# 0.5 означает 2 скана в секунду
# Уменьшите для более частого сканирования (учитывайте лимиты RPC!)
SCAN_INTERVAL_SECONDS=0.5

# Размер пула соединений с базой данных
DATABASE_POOL_SIZE=10

# Максимальное переполнение пула соединений
DATABASE_MAX_OVERFLOW=20

# Включить отладку SQL (true/false)
# Выводит все SQL запросы в лог
SQL_ECHO=false

# -----------------------------------------------------------------------------
# SECURITY SETTINGS
# -----------------------------------------------------------------------------

# Ключ шифрования для чувствительных данных
# Сгенерируйте: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=

# Включить проверку honeypot токенов (true/false)
HONEYPOT_CHECK_ENABLED=true

# Максимальная задержка перед исполнением (мс)
# Для защиты от frontrunning
MAX_EXECUTION_DELAY_MS=100

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
